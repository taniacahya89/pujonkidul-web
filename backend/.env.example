# Konfigurasi database PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_db_password_here
DB_NAME=pujon_kidul_explore

# Port server backend
PORT=8080

# API key OpenWeatherMap (dapatkan di https://openweathermap.org/api)
OWM_API_KEY=your_openweathermap_api_key_here

# Origin yang diizinkan untuk CORS (pisahkan dengan koma jika lebih dari satu)
ALLOWED_ORIGINS=http://localhost:5173

# Harga BBM per liter dalam Rupiah (Pertalite 2024)
BBM_PRICE=10000

# Koordinat Pujon Kidul untuk weather proxy
PUJON_LAT=-7.9285
PUJON_LON=122.4012
